  "@type": "sc:Dataset",
  "name": "json-join",
  "description": "Two JSON files joined via references. Regression test for issue #1030.",
  "conformsTo": "http://mlcommons.org/croissant/1.0",
  "license": "https://creativecommons.org/licenses/by/4.0/",
  "url": "https://mlcommons.org",
  "distribution": [
    {
      "@type": "cr:FileObject",
      "@id": "items",
      "name": "items",
      "contentUrl": "data/items.json",
      "encodingFormat": "application/json",
      "sha256": "09c7a515d9d49fa6f597f9103c2b54c2c13f27c4a033f780700957a18b17dcb6"
    },
    {
      "@type": "cr:FileObject",
      "@id": "prices",
      "name": "prices",
      "contentUrl": "data/prices.json",
      "encodingFormat": "application/json",
      "sha256": "88ba9ea7ce69ca5d2f03f71e0b55c5d0defa88f1299d1556b14badca10b54dd4"
    }
  ],
  "recordSet": [
    {
      "@type": "cr:RecordSet",
      "@id": "items_recordset",
      "name": "items_recordset",
      "description": "List of items.",
      "field": [
        {
          "@type": "cr:Field",
          "@id": "items_recordset/id",
          "name": "items_recordset/id",
          "description": "Item identifier.",
          "dataType": "sc:Text",
          "source": {
            "fileObject": {
              "@id": "items"
            },
            "extract": {
              "jsonPath": "$[*].id"
            }
          }
        },
        {
          "@type": "cr:Field",
          "@id": "items_recordset/name",
          "name": "items_recordset/name",
          "description": "Item name.",
          "dataType": "sc:Text",
          "source": {
            "fileObject": {
              "@id": "items"
            },
            "extract": {
              "jsonPath": "$[*].name"
            }
          }
        }
      ]
    },
    {
      "@type": "cr:RecordSet",
      "@id": "items_with_prices",
      "name": "items_with_prices",
      "description": "Items joined with their prices.",
      "field": [
        {
          "@type": "cr:Field",
          "@id": "items_with_prices/id",
          "name": "items_with_prices/id",
          "description": "Item identifier (join key).",
          "dataType": "sc:Text",
          "references": {
            "field": {
              "@id": "items_recordset/id"
            }
          },
          "source": {
            "fileObject": {
              "@id": "prices"
            },
            "extract": {
              "jsonPath": "$[*].id"
            }
          }
        },
        {
          "@type": "cr:Field",
          "@id": "items_with_prices/price",
          "name": "items_with_prices/price",
          "description": "Item price.",
          "dataType": "sc:Integer",
          "source": {
            "fileObject": {
              "@id": "prices"
            },
            "extract": {
              "jsonPath": "$[*].price"
            }
          }
        },
        {
          "@type": "cr:Field",
          "@id": "items_with_prices/name",
          "name": "items_with_prices/name",
          "description": "Item name (from items via join).",
          "dataType": "sc:Text",
          "source": {
            "field": {
              "@id": "items_recordset/name"
            }
          }
        }
      ]
    }
  ]
