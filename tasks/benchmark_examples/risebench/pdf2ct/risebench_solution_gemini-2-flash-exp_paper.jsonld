{
  "@context": {
    "croissant": "http://mlcommons.org/croissant/",
    "schema": "https://schema.org/",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@type": "croissant:TaskSolution",
  "@id": "https://github.com/PhoenixZ810/RISEBench_solution_gemini-2-flash-exp_paper",
  "schema:name": "RISEBench Solution - Gemini-2.0-Flash-Experimental",
  "schema:isBasedOn": { "@id": "https://github.com/PhoenixZ810/RISEBench" },

  "croissant:implementation": {
    "@type": "schema:SoftwareApplication",
    "@id": "https://github.com/PhoenixZ810/RISEBench_solution_gemini-2-flash-exp_paper#implementation",
    "schema:name": "Gemini-2.0-Flash-Experimental-Image-Generation (Google)",
    "schema:description": "Accessed via Google official API service."
  },

  "croissant:execution": {
    "@type": "croissant:ExecutionConfig",
    "@id": "https://github.com/PhoenixZ810/RISEBench_solution_gemini-2-flash-exp_paper#execution",
    "croissant:hyperparameter": [
      {
        "@type": "schema:PropertyValue",
        "schema:name": "evaluation_judge",
        "schema:value": "GPT-4.1"
      },
      {
        "@type": "schema:PropertyValue",
        "schema:name": "access_method",
        "schema:value": "official API"
      }
    ]
  },

  "croissant:output": {
    "@type": "schema:Dataset",
    "@id": "urn:uuid:risebench-gemini-2-flash-exp-outputs",
    "schema:name": "Gemini-2.0-Flash-Experimental outputs on RISEBench-360"
  },

