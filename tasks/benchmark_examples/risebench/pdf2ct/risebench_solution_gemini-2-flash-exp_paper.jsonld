  "croissant:evaluation": {
    "@type": "croissant:EvaluationTask",
    "@id": "https://github.com/PhoenixZ810/RISEBench_evaluation_gemini-2-flash-exp_paper",
    "schema:name": "Evaluation of Gemini-2.0-Flash-Experimental on RISEBench-360",
