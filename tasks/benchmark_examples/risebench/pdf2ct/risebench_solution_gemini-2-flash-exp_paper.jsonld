    "croissant:evaluatedSolution": { "@id": "https://github.com/PhoenixZ810/RISEBench_solution_gemini-2-flash-exp_paper" },
    "croissant:evaluationResults": [
      {
        "@type": "croissant:EvaluationResult",
        "croissant:metric": "Accuracy",
