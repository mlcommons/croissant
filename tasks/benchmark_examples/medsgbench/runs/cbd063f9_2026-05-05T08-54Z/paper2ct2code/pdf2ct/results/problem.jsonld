{
  "@context": {
    "croissant": "http://mlcommons.org/croissant/",
    "schema": "https://schema.org/",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@type": "croissant:TaskProblem",
  "@id": "http://example.org/medsg-bench",
  "schema:name": "MedSG-Bench (Medical Image Sequences Grounding Benchmark)",
  "schema:description": "MedSG-Bench is a benchmark for fine-grained visual grounding in medical image sequences. Given a sequence of medical images and a natural-language question, the model must localize the queried region by predicting bounding-box coordinates. The benchmark comprises 9,630 VQA-style samples covering 76 public medical datasets, 10 imaging modalities and 114 clinical tasks, organized into 8 tasks across two paradigms: Image Difference Grounding (detecting change regions across images) and Image Consistency Grounding (detecting consistent or shared semantics across sequential images).",
  "schema:url": "https://github.com/Yuejingkun/MedSG-Bench",
  "schema:citation": "Yue, J., Zhang, S., Jia, Z., Xu, H., Han, Z., Liu, X., & Wang, G. (2025). MedSG-Bench: A Benchmark for Medical Image Sequences Grounding. NeurIPS 2025 Track on Datasets and Benchmarks.",
  "croissant:input": {
    "@type": "croissant:InputSpec",
    "@id": "http://example.org/medsg-bench#inputSpec",
    "schema:description": "A sequence of two or more medical images (up to 6) accompanied by a natural-language instruction or question that designates the region to be localized.",
    "croissant:schema": {
      "@type": "croissant:RecordSet",
      "@id": "http://example.org/medsg-bench#inputRecordSet",
      "croissant:field": [
        {
          "@type": "croissant:Field",
          "schema:name": "image_sequence",
          "croissant:dataType": "xsd:string",
          "croissant:repeated": true,
          "schema:description": "Ordered sequence of medical images (PNG, 336x336) representing different views, modalities, time points, or registrations of the same patient or anatomical region. Provided as file paths or base64-encoded strings."
        },
        {
          "@type": "croissant:Field",
          "schema:name": "question",
          "croissant:dataType": "xsd:string",
          "schema:description": "Natural-language VQA-style instruction describing the region to ground (e.g., 'Please compare these two images carefully and ground their main difference in the second image')."
        },
        {
          "@type": "croissant:Field",
          "schema:name": "reference_region",
          "croissant:dataType": "xsd:string",
          "schema:description": "Optional reference bounding box (in one of the input images) that the model must match in the target image. Present in tasks like Multi-View Grounding, Object Tracking, Visual Concept Grounding, Visual Patch Grounding and Cross-modal Grounding."
        }
      ]
    }
  },
  "croissant:output": {
    "@type": "croissant:OutputSpec",
    "@id": "http://example.org/medsg-bench#outputSpec",
    "croissant:schema": {
      "@type": "croissant:RecordSet",
      "@id": "http://example.org/medsg-bench#outputRecordSet",
      "croissant:field": [
        {
          "@type": "croissant:Field",
          "schema:name": "predicted_bbox",
          "croissant:dataType": "xsd:integer",
          "croissant:repeated": true,
          "schema:description": "Predicted bounding box for the target region in the designated target image. Four integer coordinates. Coordinate convention is model-dependent: e.g., InternVL normalizes to [0, 1000]; Qwen2.5-VL uses absolute pixel coordinates; Gemini 2.5 Pro uses [y_min, x_min, y_max, x_max]. The benchmark normalizes coordinates per-model before computing metrics."
        }
      ]
    }
  },
  "croissant:evaluation": {
    "@type": "croissant:EvaluationSpec",
    "@id": "http://example.org/medsg-bench#evaluationSpec",
    "croissant:expectedMetric": [
      "IoU",
      "Acc@0.5"
    ],
    "schema:description": "Primary metrics: average Intersection over Union (IoU) between predicted and ground-truth bounding boxes, and Acc@0.5 (the proportion of predictions whose IoU with ground truth is at least 0.5). Models are evaluated under a zero-shot setting."
  },
  "croissant:subTask": [
    {
      "@type": "croissant:TaskProblem",
      "@id": "http://example.org/medsg-bench#registered_difference_grounding",
      "schema:name": "MedSG-Bench - Registered Difference Grounding (RDG)",
      "schema:description": "Image Difference Grounding sub-task. Given a pair of spatially aligned (registered) medical images that are visually identical except for a single region (introduced via geometric/appearance perturbations such as CutPaste or synthetic anomalies generated by state-of-the-art generative models), detect and localize the changed region. Image ordering is randomized so that either the normal or the abnormal image may appear in either position. 50 datasets, 10 modalities, 59 clinical tasks, max length 2.",
      "croissant:input": { "@id": "http://example.org/medsg-bench#inputSpec" },
      "croissant:output": { "@id": "http://example.org/medsg-bench#outputSpec" },
      "croissant:evaluation": { "@id": "http://example.org/medsg-bench#evaluationSpec" }
    },
    {
      "@type": "croissant:TaskProblem",
      "@id": "http://example.org/medsg-bench#non_registered_difference_grounding",
      "schema:name": "MedSG-Bench - Non-registered Difference Grounding (NRDG)",
      "schema:description": "Image Difference Grounding sub-task that extends Registered Difference Grounding with controlled spatial shifts: each image is randomly translated by up to 20 pixels along both horizontal and vertical axes, simulating real-world misalignment from patient movement, scanner variability, or imperfect registration. The model must identify and localize the primary difference between the two images while ignoring changes caused by misalignment. 50 datasets, 10 modalities, 58 clinical tasks, max length 2.",
      "croissant:input": { "@id": "http://example.org/medsg-bench#inputSpec" },
      "croissant:output": { "@id": "http://example.org/medsg-bench#outputSpec" },
      "croissant:evaluation": { "@id": "http://example.org/medsg-bench#evaluationSpec" }
    },
    {
      "@type": "croissant:TaskProblem",
      "@id": "http://example.org/medsg-bench#multi_view_grounding",
      "schema:name": "MedSG-Bench - Multi-View Grounding (MV)",
      "schema:description": "Image Consistency Grounding sub-task that assesses cross-view correspondence on medical images from different views (e.g., from datasets like VinDr-Mammo, or simulated by extracting three orthogonal slices - axial, sagittal, coronal - from 3D medical volumes). 30 datasets, 4 modalities, 75 clinical tasks, max length 3.",
      "croissant:input": { "@id": "http://example.org/medsg-bench#inputSpec" },
      "croissant:output": { "@id": "http://example.org/medsg-bench#outputSpec" },
      "croissant:evaluation": { "@id": "http://example.org/medsg-bench#evaluationSpec" }
    },
    {
      "@type": "croissant:TaskProblem",
      "@id": "http://example.org/medsg-bench#object_tracking",
      "schema:name": "MedSG-Bench - Object Tracking (OT)",
      "schema:description": "Image Consistency Grounding sub-task. The model must maintain consistent localization of a target object across sequential frames or slices (surgical-video frames or 3D medical volumes sliced along a fixed anatomical axis with anatomical structures or lesions as trackable targets). 30 datasets, 4 modalities, 87 clinical tasks, max length 6.",
      "croissant:input": { "@id": "http://example.org/medsg-bench#inputSpec" },
      "croissant:output": { "@id": "http://example.org/medsg-bench#outputSpec" },
      "croissant:evaluation": { "@id": "http://example.org/medsg-bench#evaluationSpec" }
    },
    {
      "@type": "croissant:TaskProblem",
      "@id": "http://example.org/medsg-bench#visual_concept_grounding",
      "schema:name": "MedSG-Bench - Visual Concept Grounding (VCG)",
      "schema:description": "Image Consistency Grounding sub-task. Given a reference image where a visually distinct and semantically coherent concept (e.g., a tumor or anatomical structure) appears under idealized conditions, identify the corresponding instance in a target image with greater visual clutter and contextual complexity. The reference concept is extracted from the target using segmentation masks to ensure semantic consistency. 49 datasets, 10 modalities, 87 clinical tasks, max length 2.",
      "croissant:input": { "@id": "http://example.org/medsg-bench#inputSpec" },
      "croissant:output": { "@id": "http://example.org/medsg-bench#outputSpec" },
      "croissant:evaluation": { "@id": "http://example.org/medsg-bench#evaluationSpec" }
    },
    {
      "@type": "croissant:TaskProblem",
      "@id": "http://example.org/medsg-bench#visual_patch_grounding",
      "schema:name": "MedSG-Bench - Visual Patch Grounding (VPG)",
      "schema:description": "Image Consistency Grounding sub-task. Match a local image patch to its original location within a larger image - challenging because structures like vertebral segments (T1 to T12) exhibit nearly identical appearances. Patches are sampled selectively (15 per image, up to 5 retained) based on foreground richness (organ boundaries, lesion areas, diagnostically relevant fine structures). 53 datasets, 10 modalities, 78 clinical tasks, max length 5.",
      "croissant:input": { "@id": "http://example.org/medsg-bench#inputSpec" },
      "croissant:output": { "@id": "http://example.org/medsg-bench#outputSpec" },
      "croissant:evaluation": { "@id": "http://example.org/medsg-bench#evaluationSpec" }
    },
    {
      "@type": "croissant:TaskProblem",
      "@id": "http://example.org/medsg-bench#cross_modal_grounding",
      "schema:name": "MedSG-Bench - Cross-modal Grounding (CMG)",
      "schema:description": "Image Consistency Grounding sub-task. Given a reference region from one image, identify the semantically or functionally equivalent region in a target image acquired with a different imaging modality (e.g., CT vs. MRI) or contrast type (e.g., T1- vs. T2-weighted MRI). Region pairs are manually curated based on metadata (modality type, annotated labels). 24 datasets, 4 modalities, 28 clinical tasks, max length 4.",
      "croissant:input": { "@id": "http://example.org/medsg-bench#inputSpec" },
      "croissant:output": { "@id": "http://example.org/medsg-bench#outputSpec" },
      "croissant:evaluation": { "@id": "http://example.org/medsg-bench#evaluationSpec" }
    },
    {
      "@type": "croissant:TaskProblem",
      "@id": "http://example.org/medsg-bench#referring_grounding",
      "schema:name": "MedSG-Bench - Referring Grounding (RG)",
      "schema:description": "Image Consistency Grounding (Vision-Language Consistency) sub-task. Interpret a natural-language referring expression and associate it with visual content across a curated set of semantically unrelated medical images, identifying the target region in the correct image. 9 datasets, 8 modalities, 28 clinical tasks, max length 3.",
      "croissant:input": { "@id": "http://example.org/medsg-bench#inputSpec" },
      "croissant:output": { "@id": "http://example.org/medsg-bench#outputSpec" },
      "croissant:evaluation": { "@id": "http://example.org/medsg-bench#evaluationSpec" }
    }
  ]
}
