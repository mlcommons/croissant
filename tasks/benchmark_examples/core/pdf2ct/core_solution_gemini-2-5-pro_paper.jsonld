  "@type": "croissant:TaskSolution",
  "@id": "http://example.org/core-benchmark_solution_gemini-2-5-pro_paper",
  "schema:name": "CoRe Solution - Gemini 2.5 Pro (paper-reported)",
  "schema:description": "TaskSolution carrying the paper-reported metrics from Xie et al. (Table 4, CoRe Lite) for Gemini 2.5 Pro. No actual run is associated with this solution; for the corresponding implementation run see ../ct2code/core_solution_gemini-2-5-pro.jsonld.",
  "schema:isBasedOn": {
    "@id": "http://example.org/core-benchmark"
  },
  "croissant:implementation": {
    "@type": "schema:SoftwareApplication",
    "@id": "http://example.org/core-benchmark_solution_gemini-2-5-pro_paper#implementation",
    "schema:name": "Google Gemini API - Gemini 2.5 Pro (paper)",
    "schema:version": "gemini-2.5-pro-preview-05-06"
  },
  "croissant:execution": {
    "@type": "croissant:ExecutionConfig",
    "@id": "http://example.org/core-benchmark_solution_gemini-2-5-pro_paper#execution",
    "croissant:hyperparameter": [
      {
        "@type": "schema:PropertyValue",
        "schema:name": "few_shot_examples",
        "schema:value": "5-7",
        "schema:description": "Number of illustrative few-shot examples drawn from small synthetic programs included in each prompt."
      },
      {
        "@type": "schema:PropertyValue",
        "schema:name": "reasoning_model",
        "schema:value": "true",
        "schema:description": "Gemini 2.5 Pro is classified as a reasoning model in the paper (Table 3)."
      },
      {
        "@type": "schema:PropertyValue",
        "schema:name": "prompt_includes_trace",
        "schema:value": "true",
        "schema:description": "Default pairwise query setting: model is asked to both classify the dependency and produce a supporting trace."
      }
    ]
  },
  "croissant:output": {
    "@type": "schema:Dataset",
    "@id": "urn:uuid:gemini-2-5-pro-paper-core-lite-outputs",
