{
  "@context": {
    "croissant": "http://mlcommons.org/croissant/",
    "schema": "https://schema.org/"
  },
  "@type": "croissant:TaskProblem",
  "@id": "http://example.org/ValidProblemWithExecutionSpec",
  "croissant:input": {
    "@type": "schema:Dataset",
    "@id": "http://example.org/concreteInput"
  },
  "croissant:output": {
    "@type": "croissant:OutputSpec",
    "@id": "http://example.org/outputSpec"
  },
  "croissant:execution": {
    "@type": "croissant:ExecutionSpec",
    "@id": "http://example.org/executionSpec"
  }
}
